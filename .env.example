# ---------------------------------------------------------------------------
# ResearchRadar — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file with real keys!
# ---------------------------------------------------------------------------

# LLM (Groq) — get your key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Telegram Bot — create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Optional: SQLite Database path (defaults to ~/.researchradar)
# RESEARCHRADAR_DB_PATH=./researchradar.db
